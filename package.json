{
  "name": "airport-parking-backend",
  "version": "1.0.0",
  "description": "Airport Parking Platform API - Zurich Airport Parking Marketplace",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "knex migrate:latest --knexfile knexfile.js",
    "db:migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "db:migrate:make": "knex migrate:make --knexfile knexfile.js",
    "db:seed": "knex seed:run --knexfile knexfile.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Tests not configured yet\" && exit 0"
  },
  "keywords": [
    "airport",
    "parking",
    "marketplace",
    "api",
    "express",
    "typescript"
  ],
  "author": "Airport Parking Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "nodemailer": "^8.0.0",
    "pg": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "nodemon": "^3.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
